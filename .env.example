# BlazeConnector v3 Environment Variables

# Application
NODE_ENV=development
PORT=3005
APP_NAME=BlazeConnector

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/blazeconnector

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Message Queue
QUEUE_CONCURRENCY=10
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_BASE_DELAY=1000
QUEUE_MAX_MESSAGES_PER_BATCH=100

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Worker Configuration
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000

# Integrations
WHATSAPP_CLOUD_URL=https://graph.facebook.com/v21.0
