{
  "name": "blazeconnector-v3",
  "version": "3.0.0",
  "type": "module",
  "description": "BlazeConnector v3 - Production-ready ISP messaging and billing platform",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "dev:node": "npx tsx watch src/index.ts",
    "start:node": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.24.0",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.0",
    "nanoid": "^5.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "@hono/zod-validator": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.1.0"
  }
}
